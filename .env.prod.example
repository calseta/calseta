# ============================================================
# Calseta AI — Production Hardened Configuration
# ============================================================
# Copy to .env on your production host and fill in real values.
# All secrets should come from a secrets manager
# (AWS Secrets Manager, Azure Key Vault, etc.) — not from this file.
#
# See docs/HOW_TO_DEPLOY.md for the full deployment guide.
# ============================================================

# Use your managed PostgreSQL DSN (RDS, Azure DB for PostgreSQL, etc.)
DATABASE_URL=postgresql+asyncpg://calseta:<password>@<host>:5432/calseta

QUEUE_BACKEND=postgres
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF_SECONDS=60

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=<generate-a-strong-random-key>

# Tune based on expected traffic
RATE_LIMIT_UNAUTHED_PER_MINUTE=30
RATE_LIMIT_AUTHED_PER_MINUTE=600
RATE_LIMIT_INGEST_PER_MINUTE=100
RATE_LIMIT_ENRICHMENT_PER_MINUTE=60
RATE_LIMIT_WORKFLOW_EXECUTE_PER_MINUTE=30

# Set to the number of load balancer / reverse proxy hops in front of the API
# AWS ALB = 1, Azure App Gateway = 1, direct = 0
TRUSTED_PROXY_COUNT=1

# Required for HSTS header
HTTPS_ENABLED=true

# Only needed if you serve a web UI or external tool from a different origin
# Leave empty if API is consumed directly by agents with no browser involved
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_ALL_ORIGINS=false

MAX_REQUEST_BODY_SIZE_MB=10
MAX_INGEST_PAYLOAD_SIZE_MB=5

LOG_LEVEL=INFO
LOG_FORMAT=json
# Set to your release tag, e.g. v1.0.0 — the release.yml CI workflow sets this automatically
APP_VERSION=v1.0.0

# Configure HMAC secrets for each active alert source.
# Generate unique secrets per source; configure matching secrets in the source system.
SENTINEL_WEBHOOK_SECRET=<generate-strong-random-secret>
ELASTIC_WEBHOOK_SECRET=<generate-strong-random-secret>
SPLUNK_WEBHOOK_SECRET=<generate-strong-random-secret>

VIRUSTOTAL_API_KEY=<your-virustotal-api-key>
ABUSEIPDB_API_KEY=<your-abuseipdb-api-key>

OKTA_DOMAIN=<your-org>.okta.com
OKTA_API_TOKEN=<your-okta-api-token>

ENTRA_TENANT_ID=<your-azure-tenant-id>
ENTRA_CLIENT_ID=<your-app-registration-client-id>
ENTRA_CLIENT_SECRET=<your-app-registration-client-secret>
