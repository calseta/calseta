# ============================================================
# Calseta — Production Configuration
# ============================================================
# Copy to .env on your production host and fill in real values.
# All secrets should come from a secrets manager
# (AWS Secrets Manager, Azure Key Vault, etc.) — not from this file.
#
# For local development defaults, see .env.local.example
# See docs/HOW_TO_DEPLOY.md for the full deployment guide.
# ============================================================


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# PostgreSQL 15+ connection string (asyncpg driver required)
# Use your managed PostgreSQL DSN (RDS, Azure DB for PostgreSQL, Cloud SQL, etc.)
DATABASE_URL=postgresql+asyncpg://calseta:<password>@<host>:5432/calseta


# ------------------------------------------------------------
# Task Queue
# ------------------------------------------------------------

# Backend: postgres (default) | celery_redis | sqs | azure_service_bus
# Only postgres is fully tested in v1. Others are stubbed.
QUEUE_BACKEND=postgres

# Only needed if queue DSN differs from DATABASE_URL
# QUEUE_POSTGRES_DSN=

# Required only for celery_redis backend
# QUEUE_REDIS_URL=redis://localhost:6379/0

# Required only for sqs backend
# QUEUE_SQS_QUEUE_URL=

# Required only for azure_service_bus backend
# QUEUE_AZURE_CONNECTION_STRING=

# Worker parallelism
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF_SECONDS=60


# ------------------------------------------------------------
# Security
# ------------------------------------------------------------

# Encryption key for sensitive fields at rest (agent auth headers, source auth configs)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=<generate-a-strong-random-key>


# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------

# Tune based on expected traffic
RATE_LIMIT_UNAUTHED_PER_MINUTE=30
RATE_LIMIT_AUTHED_PER_MINUTE=600
RATE_LIMIT_INGEST_PER_MINUTE=100
RATE_LIMIT_ENRICHMENT_PER_MINUTE=60
RATE_LIMIT_WORKFLOW_EXECUTE_PER_MINUTE=30

# Number of reverse proxy hops in front of this server.
# WARNING: Setting this > 0 trusts X-Forwarded-For for real IP detection.
# Incorrect values allow clients to spoof their IP and bypass rate limits.
# AWS ALB = 1, Azure App Gateway = 1, direct = 0
TRUSTED_PROXY_COUNT=1


# ------------------------------------------------------------
# Security Headers
# ------------------------------------------------------------

# Set to true when serving over HTTPS to enable HSTS header
HTTPS_ENABLED=true

# Disable individual headers if needed (default: all enabled)
# SECURITY_HEADER_HSTS_ENABLED=true


# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------

# Comma-separated list of allowed origins. Leave empty to disable CORS entirely.
# Example: https://my-app.example.com,https://other.example.com
# Only needed if you serve a web UI or external tool from a different origin.
# Leave empty if API is consumed directly by agents with no browser involved.
CORS_ALLOWED_ORIGINS=

# WARNING: Never set to true in production — disables all CORS restrictions
CORS_ALLOW_ALL_ORIGINS=false


# ------------------------------------------------------------
# Request Body Limits
# ------------------------------------------------------------

MAX_REQUEST_BODY_SIZE_MB=10
MAX_INGEST_PAYLOAD_SIZE_MB=5


# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

# Minimum log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output format: json (production) | text (local dev)
LOG_FORMAT=json

# Included in every log line. Set to git tag in CI via release workflow.
APP_VERSION=v1.0.0


# ------------------------------------------------------------
# Webhook Signing Secrets (inbound from source systems)
# ------------------------------------------------------------

# Configure HMAC secrets for each active alert source.
# Generate unique secrets per source; configure matching secrets in the source system.
# Each source's docs/integrations/{source}/api_notes.md describes the signing mechanism.
SENTINEL_WEBHOOK_SECRET=<generate-strong-random-secret>
ELASTIC_WEBHOOK_SECRET=<generate-strong-random-secret>
SPLUNK_WEBHOOK_SECRET=<generate-strong-random-secret>


# ------------------------------------------------------------
# Enrichment Providers
# ------------------------------------------------------------

# VirusTotal — IP, domain, file hash enrichment
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=<your-virustotal-api-key>

# AbuseIPDB — IP abuse confidence scoring
# https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=<your-abuseipdb-api-key>

# Okta — Account enrichment and pre-built workflows (suspend, revoke sessions, etc.)
OKTA_DOMAIN=<your-org>.okta.com
OKTA_API_TOKEN=<your-okta-api-token>

# Microsoft Entra (Azure AD) — Account enrichment and pre-built workflows
ENTRA_TENANT_ID=<your-azure-tenant-id>
ENTRA_CLIENT_ID=<your-app-registration-client-id>
ENTRA_CLIENT_SECRET=<your-app-registration-client-secret>


# ------------------------------------------------------------
# Agent Webhook Dispatch
# ------------------------------------------------------------

# Public base URL of this Calseta API instance. Included in agent webhook payloads
# so agents can make callback requests (e.g., POST findings, update alert status).
# Set to the externally reachable URL (e.g. https://calseta.example.com)
CALSETA_API_BASE_URL=https://calseta.example.com
